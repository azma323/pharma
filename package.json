{
  "name": "bdt",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "homepage": ".",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.bdtsoft.pos",
    "productName": "BDT POS Pharmacy",
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-barcode": "^1.5.3",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "sweetalert2": "^11.26.24",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}